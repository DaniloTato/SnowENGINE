let fib = (n){
	if ($n <= 1) do[
		return $n;
 	]done else do[
		return ($fib($n-1) + $fib($n-2));
	]done;
};

let dotimes = (block,n){
	if ($n > 0) do[
		$block();
		$dotimes($block, $n - 1);
	]done;
};

